  m_IsActive: 1
--- !u!114 &633153526
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 633153525}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d41670dcfcaa5b3429efb9acc64ebc6f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
    dialogueLines:
    - character:
        name: "\xC9lodie"
        icon: {fileID: 0}
      line: Excuse me.
    - character:
        name: "\xC9lodie"
        icon: {fileID: 0}
      line: I'm looking for Giselle.
    - character:
        name: Giselle
        icon: {fileID: 0}
      line: That's me.
    - character:
        name: Giselle
        icon: {fileID: 0}
      line: If you've gone through the effort of looking for me, I assume you have
        an object you want me to take a look at.
    - character:
        name: "\xC9lodie"
        icon: {fileID: 0}
      line: That's right...
    - character:
        name: "\xC9lodie"
        icon: {fileID: 0}
      line: Could you take a look at this for me, please?
    - character:
        name: "\xC9lodie"
        icon: {fileID: 0}
      line: It was my older sister's wedding gift from the Sinclairs, gifted to her
        right before she left overseas.
    - character:
        name: "\xC9lodie"
        icon: {fileID: 0}
      line: I heard about her passing only a couple of weeks ago.
    - character:
        name: "\xC9lodie"
        icon: {fileID: 0}
      line: Could you help me, please...?
    - character:
        name: "\xC9lodie"
        icon: {fileID: 0}
      line: It's been so long, but no matter what I do, I can't move on.
    - character:
        name: "\xC9lodie"
        icon: {fileID: 0}
      line: It's as if this lack of knowledge about her prevents me from truly processing
        my grief and her death.
    - character:
        name: Giselle
        icon: {fileID: 0}
      line: Don't worry, that's what I'm here for.
    - character:
        name: Giselle
        icon: {fileID: 0}
      line: I'll do what I can to help you know your sister.
  rewardItem: {fileID: 11400000, guid: 8c8fb9c7b26d9ac458097c667e085e56, type: 2}
